<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom theme for Noon SDK activities that keeps content away from system bars -->
    <style name="NoonPayments.SafeTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="android:fitsSystemWindows">true</item>
        <!-- Opaque system bars to prevent content from going behind them -->
        <item name="android:statusBarColor">#FFFFFFFF</item>
        <item name="android:navigationBarColor">#FFFFFFFF</item>
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <!-- Prevent drawing in the display cutout (notch) area -->
        <item name="android:windowLayoutInDisplayCutoutMode">never</item>
        <!-- Disable edge-to-edge enforcement -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>
</resources>
